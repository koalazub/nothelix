node_modules/
build/
.build/
target/
*.o
*.so
*.dylib
*.wasm
!docs/assets/eng/wasm/*.wasm
.DS_Store

# Nix build output symlink
/result

# Plugin kernel temp files
/tmp/helix-kernel-*

# Test notebooks
*.ipynb.bak
test-*.ipynb

# Editor
*.swp
*.swo
*~

# Image cache (generated by nothelix during cell execution)
.nothelix/

# Julia LSP depot — populated by `just install` on first run.
# Vendored package sources, compiled .ji / .dylib caches, scratchspaces,
# and the general registry tarball all belong to the user's local depot
# and should not be tracked. The manifest is enough to reconstruct it.
lsp/depot/

# Home-manager leaves .hm-bak files when it rebuilds over a symlinked
# tree. These are recoverable — not something we ever want to commit.
*.hm-bak
docs/vendor/
docs/Gemfile.lock

# Agent tooling scratch — session-local, never tracked
.claude/
.superpowers/
