#!/bin/bash
set -euo pipefail

NOXDIR="${XDG_DATA_HOME:-$HOME/.local/share}/nothelix/lsp"

# Keep LanguageServer + its deps isolated in $NOXDIR/depot, but also
# expose the user's real Julia depot ($HOME/.julia) so the LSP can
# *read* the packages they've actually installed (LinearAlgebra,
# Plots, Makie, whatever Pkg.add pulled in from their notebook cells).
# Without the second entry, the LSP analyses against a depot that
# only knows LanguageServer.jl, and every stdlib-backed name like
# `norm` shows up as an undefined reference with no hover doc.
#
# NB: the bootstrap depot comes FIRST so its precompile artifacts
# win over anything in the shared depot, and we never write into
# $HOME/.julia from the LSP.
export JULIA_DEPOT_PATH="$NOXDIR/depot:$HOME/.julia"

# Don't override HOME. The previous version of this script set
# HOME=$NOXDIR as a belt-and-braces isolation measure, but that
# also hid the user's real `~/.julia/environments/v1.x` from
# `homedir()` — which is exactly the env the LSP needs to analyse.
# `--startup-file=no` below already skips `~/.julia/config/startup.jl`
# so there's no need to fake HOME to avoid it.

# Startup script configures LanguageServer.jl for notebook-converted files:
#
# 1. Defines the `@cell` and `@markdown` marker macros as no-ops that
#    return `nothing`. Previously `esc(last(args))` caused
#    `@cell 13 julia` to expand to the bare identifier `julia`, producing
#    "Missing reference: julia" on every cell header. Returning `nothing`
#    emits no AST nodes for StaticLint to chase.
#
# 2. Disables StaticLint's missing-reference warnings (`lint_missingrefs =
#    :none`). These are false positives for notebook-style code because
#    the LSP analyses one file at a time with no awareness of runtime
#    state from prior cells. The actual compile errors come from the
#    Julia kernel during execution, which is the source of truth here.
#
# 3. Monkey-patches `LanguageServer.request_julia_config` to a no-op.
#    That function normally pulls `julia.lint.missingrefs` from the
#    LSP client config and RESETS `server.lint_missingrefs` to whatever
#    the client returned (defaulting to `:all` if unset). Helix doesn't
#    expose a way to pass this key, so the post-init config refresh
#    silently undoes our `:none` setting. Overriding it as a no-op
#    keeps our initial configuration sticky.
#
# 4. Picks the env to ANALYSE explicitly instead of letting
#    `LanguageServer.choose_env()` fall back to the bootstrap
#    `--project=$NOXDIR` (which only has LanguageServer.jl in it and
#    can't resolve any of the user's stdlib / registered packages).
#    Walks up from `pwd` looking for a `Project.toml` first so
#    workspaces with their own env win, and falls back to the user's
#    shared `v$(major).$(minor)` environment under `homedir()` —
#    which is where `Pkg.add` from an interactive session actually
#    installs things.
exec julia \
  --startup-file=no \
  --history-file=no \
  --quiet \
  "--project=$NOXDIR" \
  -e 'macro cell(args...) nothing end
      macro markdown(args...) nothing end
      using LanguageServer
      @eval LanguageServer begin
          function request_julia_config(server::LanguageServerInstance, conn)
              nothing
          end
      end
      function pick_user_env()
          dir = pwd()
          while true
              isfile(joinpath(dir, "Project.toml")) && return dir
              parent = dirname(dir)
              parent == dir && break
              dir = parent
          end
          shared = joinpath(homedir(), ".julia", "environments",
                            "v$(VERSION.major).$(VERSION.minor)")
          isdir(shared) && return shared
          return LanguageServer.choose_env()
      end
      let env_path = pick_user_env()
          server = LanguageServer.LanguageServerInstance(stdin, stdout, env_path, "", nothing, nothing)
          server.lint_missingrefs = :none
          run(server)
      end'
