#!/bin/bash
set -euo pipefail

NOXDIR="${XDG_DATA_HOME:-$HOME/.local/share}/nothelix/lsp"

# Stack the bootstrap env ($NOXDIR, which has LanguageServer +
# NothelixMacros) onto JULIA_LOAD_PATH so Julia can `using` them
# from any active project. The user's default env (@v#.#) and
# stdlib stay in the path via the default entries.
#
# This replaces the old --project=$NOXDIR flag which forced the
# active project to $NOXDIR, causing LanguageServer to analyze
# against an env that only had LanguageServer itself — which is
# why every package reference showed as "Missing reference".
export JULIA_LOAD_PATH="$NOXDIR:@:@v#.#:@stdlib"
export JULIA_DEPOT_PATH="$NOXDIR/depot:$HOME/.julia"

exec julia \
  --startup-file=no \
  --history-file=no \
  --quiet \
  -e 'macro cell(args...) nothing end
      macro markdown(args...) nothing end
      using LanguageServer
      @eval LanguageServer begin
          function request_julia_config(server::LanguageServerInstance, conn)
              nothing
          end
      end
      let env_path = LanguageServer.choose_env()
          server = LanguageServer.LanguageServerInstance(stdin, stdout, env_path, "", nothing, nothing)
          server.lint_missingrefs = :all
          run(server)
      end'
